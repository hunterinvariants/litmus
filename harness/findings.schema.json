{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Litmus tool findings",
  "type": "object",
  "required": ["tool", "findings"],
  "properties": {
    "tool": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "contract", "vuln_class"],
        "properties": {
          "case_id": { "type": "string" },
          "contract": { "type": "string" },
          "function": { "type": "string" },
          "lines": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          },
          "vuln_class": { "type": "string" },
          "severity": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
